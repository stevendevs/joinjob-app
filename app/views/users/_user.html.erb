<div class="border rounded-lg shadow-md p-4 bg-white">
  <div class="flex items-center space-x-2 mb-4 text-gray-700 font-semibold text-lg">
    <i class="fa fa-user text-blue-500"></i>
    <span><%= user.email %></span>
  </div>

  <div class="text-sm text-gray-600 mb-2">
    <span>Signed up <%= time_ago_in_words(user.created_at) %> ago</span>
  </div>

  <div class="text-sm text-gray-600 mb-2">
    <span class="font-medium"><%= 'sign_in_count'.humanize %>:</span>
    <span><%= user.sign_in_count %></span>
  </div>

  <div class="space-y-1 text-sm text-gray-600">
    <div class="flex space-x-2">
      <span class="font-medium"><%= 'current_sign_in_at'.humanize %>:</span>
      <span><%= user.current_sign_in_at %></span>
    </div>
    <div class="flex space-x-2">
      <span class="font-medium"><%= 'last_sign_in_at'.humanize %>:</span>
      <span><%= user.last_sign_in_at %></span>
    </div>
    <div class="flex space-x-2">
      <span class="font-medium"><%= 'current_sign_in_ip'.humanize %>:</span>
      <span><%= user.current_sign_in_ip %></span>
    </div>
    <div class="flex space-x-2">
      <span class="font-medium"><%= 'last_sign_in_ip'.humanize %>:</span>
      <span><%= user.last_sign_in_ip %></span>
    </div>
   



    <div class="mt-4 border-t pt-3 flex items-center space-x-2 text-sm font-semibold text-gray-700">
      <span>Confirmed email?</span>
      <% if user.confirmed_at.present? %>
        <span class="inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
          Yes
        </span>
      <% else %>
        <span class="inline-block bg-red-100 text-red-800 text-xs font-semibold px-2 py-1 rounded-full">
          No
        </span>
      <% end %>
    </div>







  </div>
</div>
