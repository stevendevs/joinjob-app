<!-- Tabla de Usuarios -->
<div class="overflow-x-auto pt-16">
  <table class="min-w-full bg-white border rounded shadow text-sm">
    <thead class="bg-gray-100 text-gray-600 uppercase text-xs border-b">
      <tr>
        <th class="px-4 py-3 text-left">Email</th>
        <th class="px-4 py-3 text-left">Ingresos</th>
        <th class="px-4 py-3 text-left">Último acceso</th>
        <th class="px-4 py-3 text-left">Estado</th>
        <th class="px-4 py-3 text-left">Acciones</th>
      </tr>
    </thead>
    <tbody class="text-gray-700">
      <% @users.each do |user| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="px-4 py-3"><%= user.email %></td>
          <td class="px-4 py-3"><%= user.sign_in_count %></td>
          <td class="px-4 py-3"><%= user.last_sign_in_at&.strftime("%Y-%m-%d %H:%M") || "Nunca" %></td>
          <td class="px-4 py-3">
            <% if user.confirmed_at? %>
              <span class="text-green-600 font-semibold">✔ Confirmado</span>
            <% else %>
              <span class="text-red-500 font-semibold">✖ Sin confirmar</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <%= link_to 'Editar', edit_user_path(user), class: 'text-blue-600 hover:underline text-xs' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
