          <td class="px-6 py-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              <div class="w-2 h-2 mr-1 bg-green-500 rounded-full"></div>
              Confirmed
            </span>
          </td>
          <td class="px-6 py-4">
            <div class="flex space-x-2">
