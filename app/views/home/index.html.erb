


<!-- Main container with light background -->
<div class="w-full h-screen bg-gray-50 flex pt-16">
  
  <!-- Left Sidebar - 1/6 width -->
  <div class="w-1/6 h-screen bg-white border-r border-gray-200">
    <aside class="hidden lg:block sticky top-0 pt-8">
      <div class="p-4">
        <h3 class="font-bold text-lg mb-4 text-gray-800">Navigation</h3>
        <ul class="space-y-1">
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Home</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Explore</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Notifications</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Messages</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Bookmarks</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Profile</li>
        </ul>
      </div>
    </aside>
  </div>
  
  <!-- Main Content - 4/6 width -->
  <div class="w-4/6 h-screen bg-gray-100 overflow-y-auto">
    <!-- Header Section -->
    <div class="w-full bg-white py-12 mb-6 border-b border-gray-200">
      <div class="text-center max-w-3xl mx-auto px-4">
        <!-- Heading -->
        <h2 class="text-3xl font-bold text-gray-800">
          This is <span class="px-2 text-white bg-blue-500 rounded">heading</span>
        </h2>



        <div class="w-full bg-white py-12 mb-6 border-b border-gray-200">
        <div class="text-center max-w-3xl mx-auto px-4 space-y-6">
       
          <!-- Search -->
          <%= form_tag(courses_path, method: :get, class: "flex items-center justify-center w-full") do %>
            <div class="relative w-full max-w-xs">
              <%= text_field_tag :title, params[:title], autocomplete: 'off', placeholder: "Buscar...",
                  class: "block w-full p-2 pr-10 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" %>
    
              <button type="submit"
                class="absolute right-0 top-0 bottom-0 px-3 text-sm font-medium text-white bg-blue-600 rounded-r-lg hover:bg-blue-700 focus:ring-2 focus:outline-none focus:ring-blue-300 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m0 0A7 7 0 1 0 9 9a7 7 0 0 0 6 6z" />
                </svg>
              </button>
            </div>
          <% end %>
        </div>
      </div>
      </div>
    </div>
    
    <!-- Feed Content -->
    <div class="px-4 pb-8">
      <!-- Create Post -->
      <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gray-200"></div>
          <input type="text" placeholder="What's on your mind?" class="w-full px-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg">
        </div>
        <div class="flex justify-end">
          <button class="px-4 py-2 text-sm text-white bg-blue-500 rounded-lg">
            Share
          </button>
        </div>
      </div>

      <!-- Posts - Static Version -->
      <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gray-200"></div>
          <div>
            <h3 class="font-semibold">User Name</h3>
            <p class="text-xs text-gray-500">2 hours ago</p>
          </div>
        </div>
        <p class="mb-4">
          This is a sample post content. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
        </p>
        <div class="aspect-video bg-gray-200 rounded-lg mb-4"></div>
        <div class="flex items-center gap-4 text-gray-500 text-sm">
          <button class="hover:text-blue-500">Like • 24</button>
          <button class="hover:text-blue-500">Comment • 5</button>
          <button class="hover:text-blue-500">Share</button>
        </div>
      </div>
      
      <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gray-200"></div>
          <div>
            <h3 class="font-semibold">Another User</h3>
            <p class="text-xs text-gray-500">5 hours ago</p>
          </div>
        </div>
        <p class="mb-4">
          Another sample post with different content. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>
        <div class="flex items-center gap-4 text-gray-500 text-sm">
          <button class="hover:text-blue-500">Like • 12</button>
          <button class="hover:text-blue-500">Comment • 3</button>
          <button class="hover:text-blue-500">Share</button>
        </div>
      </div>
      
      <!-- You can use ERB for dynamic content if needed -->
      <% if @show_more_posts %>
        <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-gray-200"></div>
            <div>
              <h3 class="font-semibold">Third User</h3>
              <p class="text-xs text-gray-500">Yesterday</p>
            </div>
          </div>
          <p class="mb-4">
            A third post example. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.
          </p>
          <div class="aspect-video bg-gray-200 rounded-lg mb-4"></div>
          <div class="flex items-center gap-4 text-gray-500 text-sm">
            <button class="hover:text-blue-500">Like • 36</button>
            <button class="hover:text-blue-500">Comment • 8</button>
            <button class="hover:text-blue-500">Share</button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Right Sidebar - 1/6 width -->
  <div class="w-1/6 h-screen bg-white border-l border-gray-200">
    <aside class="hidden lg:block sticky top-0 pt-8">
      <div class="p-4">
        <h3 class="font-bold text-lg mb-4 text-gray-800">Trending Topics</h3>
        <div class="space-y-3">
          <div class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">
            <p class="text-xs text-gray-500">Trending in Technology</p>
            <p class="font-medium">#TrendingTopic1</p>
            <p class="text-xs text-gray-500">5.2K posts</p>
          </div>
          <div class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">
            <p class="text-xs text-gray-500">Trending in Science</p>
            <p class="font-medium">#TrendingTopic2</p>
            <p class="text-xs text-gray-500">3.8K posts</p>
          </div>
        </div>
        
        <div class="mt-6">
          <h3 class="font-bold text-lg mb-4 text-gray-800">Who to Follow</h3>
          <div class="space-y-3">
            <div class="p-2 hover:bg-gray-100 rounded-md">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-gray-200"></div>
                  <div>
                    <p class="font-medium">User Name</p>
                    <p class="text-xs text-gray-500">@username</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>










<div class="min-h-screen pt-16 ">
<!-- Main 3-column layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 max-w-screen-2xl mx-auto px-4">
  
  <!-- Left Sidebar (Empty for now) -->
  <aside class="hidden lg:block lg:col-span-2 sticky top-4 self-start">
    <div class="bg-white rounded-lg shadow-sm p-4 mb-4">
      <!-- Left sidebar content will go here -->
      <h3 class="font-bold text-lg mb-4">Navigation</h3>
      <ul class="space-y-2">
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Home</li>
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Explore</li>
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Notifications</li>
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Messages</li>
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Bookmarks</li>
        <li class="p-2 hover:bg-gray-50 rounded-md cursor-pointer">Profile</li>
      </ul>
    </div>
  </aside>
  
  <!-- Main Content (Middle Column) -->
  <main class="lg:col-span-7 space-y-6">
    <!-- Hero Section -->
    <div class="w-full bg-gray-50 rounded-xl py-16 mb-6">
      <div class="text-center max-w-3xl mx-auto px-4">
        <div class="space-y-6">
          <!-- Heading -->
          <h2 class="text-4xl md:text-5xl font-bold text-gray-900">
            This is <span class="px-2 text-white bg-blue-600 rounded">heading</span> 👋
          </h2>

          <!-- Search Form -->
          <form class="flex justify-center items-center gap-2 mt-6">
            <input type="text" placeholder="Search courses" 
                class="w-full max-w-xs px-4 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">

            <button type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Newest Courses Section -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Newest Courses</h2>

      <div class="w-full">
      <% if @latest_courses.any? %>
      <div class="grid grid-cols-1 md:grid-cols-1 gap-6">
        <% @latest_courses.each do |course| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
            <div class="p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                <%= link_to course.title, course_path(course), class: "hover:text-blue-600 transition-colors" %>
              </h2>
              <p class="text-xs text-gray-500 mt-2">Created by: <%= course.user %></p>
              <p class="text-xs text-gray-500">Created at: <%= course.created_at.strftime("%b %d, %Y") %></p>

              <div class="flex justify-end gap-2 mt-4">
                <%= link_to "Show", course, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-gray-100 text-gray-800 hover:bg-gray-200 transition-colors" %>
                <%= link_to "Edit", edit_course_path(course), class: "px-3 py-1.5 text-xs font-medium rounded-md bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition-colors" %>
                <%= button_to "Destroy", course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-red-600 text-white hover:bg-red-700 transition-colors" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center my-10 text-gray-600">No courses found.</p>
    <% end %>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t-2 border-gray-100 my-10"></div>

    <!-- Popular Section -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Popular</h2>

      <div class="w-full">
      <% if @courses.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @courses.each do |course| %>
