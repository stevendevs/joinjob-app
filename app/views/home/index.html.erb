<div class="min-h-screen bg-gray-50">
  <!-- Main 3-column layout -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 max-w-screen-2xl mx-auto">
    
    <!-- Left Sidebar -->
    <aside class="hidden lg:block lg:col-span-2 sticky top-4 self-start h-screen border-r border-gray-200">
      <div class="p-4">
        <h3 class="font-bold text-lg mb-4 text-gray-800">Navigation</h3>
        <ul class="space-y-1">
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Home</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Explore</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Notifications</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Messages</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Bookmarks</li>
          <li class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">Profile</li>
        </ul>
      </div>
    </aside>
    
    <!-- Main Content (Middle Column) -->
    <main class="lg:col-span-7 space-y-6 px-4 py-8">
      <!-- Hero Section -->
      <div class="w-full bg-white py-12 mb-6 border-b border-gray-200 rounded-lg">
        <div class="text-center max-w-3xl mx-auto px-4 space-y-6">
          <!-- Heading -->
          <h2 class="text-3xl font-bold text-gray-800">
            This is <span class="px-2 text-white bg-blue-500 rounded">heading</span>
          </h2>

          <!-- Search Form -->
          <%= form_tag(courses_path, method: :get, class: "flex items-center justify-center w-full mt-6") do %>
            <div class="relative w-full max-w-xs">
              <%= text_field_tag :title, params[:title], autocomplete: 'off', placeholder: "Buscar...",
                  class: "block w-full p-2 pr-10 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" %>
    
              <button type="submit"
                class="absolute right-0 top-0 bottom-0 px-3 text-sm font-medium text-white bg-blue-600 rounded-r-lg hover:bg-blue-700 focus:ring-2 focus:outline-none focus:ring-blue-300 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m0 0A7 7 0 1 0 9 9a7 7 0 0 0 6 6z" />
                </svg>
              </button>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Newest Courses Section -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Newest Courses</h2>

        <div class="w-full">
          <% if @latest_courses.any? %>
            <div class="grid grid-cols-1 gap-4">
              <% @latest_courses.each do |course| %>
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                  <div class="p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-2">
                      <%= link_to course.title, course_path(course), class: "hover:text-blue-600 transition-colors" %>
                    </h2>
                    <p class="text-xs text-gray-500 mt-2">Created by: <%= course.user %></p>
                    <p class="text-xs text-gray-500">Created at: <%= course.created_at.strftime("%b %d, %Y") %></p>

                    <div class="flex justify-end gap-2 mt-4">
                      <%= link_to "Show", course, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-gray-100 text-gray-800 hover:bg-gray-200 transition-colors" %>
                      <%= link_to "Edit", edit_course_path(course), class: "px-3 py-1.5 text-xs font-medium rounded-md bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition-colors" %>
                      <%= button_to "Destroy", course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-red-600 text-white hover:bg-red-700 transition-colors" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center my-10 text-gray-600">No courses found.</p>
          <% end %>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-gray-200 my-8"></div>

      <!-- Popular Section -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Popular</h2>

        <div class="w-full">
          <% if @courses.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <% @courses.each do |course| %>
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                  <div class="p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-2">
                      <%= link_to course.title, course_path(course), class: "hover:text-blue-600 transition-colors" %>
                    </h2>
                    <p class="text-xs text-gray-500 mt-2">Created by: <%= course.user %></p>
                    <p class="text-xs text-gray-500">Created at: <%= course.created_at.strftime("%b %d, %Y") if course.respond_to?(:created_at) %></p>

                    <div class="flex justify-end gap-2 mt-4">
                      <%= link_to "Show", course, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-gray-100 text-gray-800 hover:bg-gray-200 transition-colors" %>
                      <%= link_to "Edit", edit_course_path(course), class: "px-3 py-1.5 text-xs font-medium rounded-md bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition-colors" %>
                      <%= button_to "Destroy", course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-red-600 text-white hover:bg-red-700 transition-colors" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center my-10 text-gray-600">No courses found.</p>
          <% end %>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-gray-200 my-8"></div>

      <!-- Top Rating Section -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Top Rating</h2>

        <div class="w-full">
          <% if @courses.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <% @courses.each do |course| %>
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                  <div class="p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-2">
                      <%= link_to course.title, course_path(course), class: "hover:text-blue-600 transition-colors" %>
                    </h2>
                    <p class="text-xs text-gray-500 mt-2">Created by: <%= course.user %></p>
                    <p class="text-xs text-gray-500">Created at: <%= course.created_at.strftime("%b %d, %Y") if course.respond_to?(:created_at) %></p>

                    <div class="flex justify-end gap-2 mt-4">
                      <%= link_to "Show", course, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-gray-100 text-gray-800 hover:bg-gray-200 transition-colors" %>
                      <%= link_to "Edit", edit_course_path(course), class: "px-3 py-1.5 text-xs font-medium rounded-md bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition-colors" %>
                      <%= button_to "Destroy", course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-3 py-1.5 text-xs font-medium rounded-md bg-red-600 text-white hover:bg-red-700 transition-colors" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-center my-10 text-gray-600">No courses found.</p>
          <% end %>
        </div>
      </div>
    </main>
    
    <!-- Right Sidebar -->
    <aside class="hidden lg:block lg:col-span-3 sticky top-4 self-start h-screen border-l border-gray-200">
      <div class="p-4">
        <h3 class="font-bold text-lg mb-4 text-gray-800">Stats Overview</h3>
        
        <!-- Stats Cards (Vertical Layout) -->
        <div class="space-y-4">
          <!-- Card 1: Total Courses -->
          <div class="bg-white rounded-lg shadow-sm p-4 text-center hover:shadow-md transition-shadow border border-gray-100">
            <div class="text-3xl text-blue-500 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-gray-800">125</p>
            <p class="text-gray-600 font-medium">Online Courses</p>
            <div class="mt-2 text-xs text-gray-500">Explore a variety of fresh topics</div>
          </div>

          <!-- Card 2: Instructors -->
          <div class="bg-white rounded-lg shadow-sm p-4 text-center hover:shadow-md transition-shadow border border-gray-100">
            <div class="text-3xl text-blue-500 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-gray-800">42</p>
            <p class="text-gray-600 font-medium">Expert Instructors</p>
            <div class="mt-2 text-xs text-gray-500">Find the right instructor for you</div>
          </div>

          <!-- Card 3: Active Learners -->
          <div class="bg-white rounded-lg shadow-sm p-4 text-center hover:shadow-md transition-shadow border border-gray-100">
            <div class="text-3xl text-blue-500 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-gray-800">1,250</p>
            <p class="text-gray-600 font-medium">Active Learners</p>
            <div class="mt-2 text-xs text-gray-500">Join the knowledge sharing community</div>
          </div>
        </div>
        
        <!-- Trending Topics -->
        <div class="mt-8">
          <h3 class="font-bold text-lg mb-4 text-gray-800">Trending Topics</h3>
          <div class="space-y-3">
            <div class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">
              <p class="text-xs text-gray-500">Trending in Technology</p>
              <p class="font-medium">#WebDevelopment</p>
              <p class="text-xs text-gray-500">5.2K courses</p>
            </div>
            <div class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">
              <p class="text-xs text-gray-500">Trending in Science</p>
              <p class="font-medium">#DataScience</p>
              <p class="text-xs text-gray-500">3.8K courses</p>
            </div>
            <div class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">
              <p class="text-xs text-gray-500">Trending in Design</p>
              <p class="font-medium">#UXDesign</p>
              <p class="text-xs text-gray-500">2.4K courses</p>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>
