<%= simple_form_for(course, html: { class: "space-y-6 bg-white p-8 rounded-2xl shadow-md max-w-3xl mx-auto" }) do |f| %>
  <% if course.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg border border-red-300">
      <h2 class="font-semibold mb-2"><%= pluralize(course.errors.count, "error") %> impidieron guardar el curso:</h2>
      <ul class="list-disc list-inside text-sm">
        <% course.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.input :title, label_html: { class: "font-semibold" }, input_html: { class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>

  <%= f.input :short_description, as: :text, label_html: { class: "font-semibold" },
      input_html: { rows: 2, class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>

  <div>
    <%= f.label :description, class: "block font-semibold mb-1" %>
    <%= f.rich_text_area :description, class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <small class="text-red-500"><%= f.error :description %></small>
  </div>

  <%= f.input :price, as: :integer, label_html: { class: "font-semibold" },
      input_html: { class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>

  <%= f.input :language, label_html: { class: "font-semibold" }, collection: ["English", "Polish", "Russian"],
      prompt: "Select language",
      input_html: { class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>

  <%= f.input :level, label_html: { class: "font-semibold" }, collection: ["Beginner", "Intermediate", "Advanced"],
      prompt: "Select level",
      input_html: { class: "w-full border rounded-md px-4 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>

  <div>
    <%= f.button :submit, "Guardar curso",
        class: "w-full sm:w-auto rounded-md bg-blue-600 hover:bg-blue-500 text-white font-medium px-6 py-3 transition" %>
  </div>
<% end %>
