

<% content_for :title, "Courses" %>

<div class="flex flex-col w-full"> 




<div class="flex justify-between items-center mb-4">
<h1 class="font-bold text-4xl text-center">Courses: <%= @courses.count %></h1>

<div class="flex space-x-3">
<%= link_to "back", root_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
<%= link_to "New course", new_course_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>


</div>
</div>
<div class="w-full h-screen overflow-x-auto rounded-box border border-base-content/5 bg-base-100 p-5">



  <% if @courses.any? %>
    <table class="table w-full">
      <!-- Table Head -->
      <thead>
        <tr>
          <th></th>
          <th>Name</th>
          <th>Description</th>
          <th>user_id</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <!-- Table Body -->
      <tbody>
        <% @courses.each_with_index do |course, index| %>
          <tr>
            <th><%= course.id %></th>
            <td><%= course.title %></td>
            <td><%= course.description  %></td>
            <td><%= course.user  %></td>
            <td>
              <div class="flex flex-col sm:flex-row gap-2 justify-center items-center">
                <%= link_to "Show", course, class: "text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
                <%= link_to "Edit", edit_course_path(course), class: "text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
                <%= button_to "Destroy", course, method: :delete, class: "rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center my-10">No courses found.</p>
  <% end %>
</div>
</div>
