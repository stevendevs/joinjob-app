<div id="<%= dom_id course %>" class="card bg-base-100 shadow-sm border border-base-content/5 dark:border-white/10 dark:bg-neutral text-neutral-content w-full sm:w-auto my-5">
  <div class="card-body space-y-2">


    <!-- Título como enlace -->
    <h2 class="card-title text-neutral dark:text-white">
      <%= link_to course.title, course_path(course), class: "hover:underline" %>
    </h2>

    <!-- Descripción -->
    <p class="text-neutral-content dark:text-gray-300"><%= course.description %></p>

    <!-- Metadata opcional -->
    <p class="text-xs text-gray-400">Created by: <%= course.user %></p>
    <p class="text-xs text-gray-400">Created at: <%= course.created_at.strftime("%b %d, %Y") if course.respond_to?(:created_at) %></p>

    <!-- Acciones -->
    <div class="card-actions justify-end mt-4">

      <%= link_to "Edit", edit_course_path(course), class: "btn btn-sm bg-yellow-100 hover:bg-yellow-200 text-yellow-800 dark:bg-yellow-700 dark:hover:bg-yellow-600 dark:text-white" %>
      <%= button_to "Destroy", course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm bg-red-600 hover:bg-red-500 text-white dark:bg-red-700 dark:hover:bg-red-600" %>
    </div>
    
  </div>
</div>
