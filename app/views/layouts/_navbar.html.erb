<% if current_user %>
<div class="flex items-center justify-between space-x-4 bg-sky-400">
  <span class="text-gray-700 font-medium"><%= current_user.email %></span>
  <div >
  <%= link_to 'Account settings', edit_user_registration_path, class: "text-blue-600 hover:underline" %>
  <%= link_to 'Sign out', destroy_user_session_path, data: { turbo_method: :delete }, class: "text-red-600 hover:underline" %>
   </div>
</div>
<% else %>
<div class="flex items-center justify-end space-x-4 bg-sky-400">
  <%= link_to 'Sign Up', new_user_registration_path, class: "text-green-600 hover:underline" %>
  <%= link_to 'Log In', new_user_session_path, class: "text-blue-600 hover:underline" %>
</div>
<% end %>
