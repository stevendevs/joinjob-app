
<div class="w-full pt-14 bg-indigo-900 flex">
 




<!-- Sidebar -->

<div class="w-64 h-[calc(100vh-4rem)] bg-gradient-to-b bg-blue-500 text-white shadow-lg relative">
<!-- Logo or title section -->
<div class="p-5 border-b border-white/20">
  <div class="flex justify-end w-full">
    <%= link_to "Courses", courses_path, data: { turbo_frame: :dashboard }, 
    class: "text-sm font-medium bg-white text-purple-600 hover:bg-purple-100 px-4 py-2 rounded-full transition-colors duration-200 shadow-md" %>
  </div>
</div>

<!-- Navigation elements -->
<div class="p-4 space-y-4">
  <%= link_to users_path,  
  data: { turbo_frame: :dashboard },
  class: 'flex items-center space-x-3 p-3 rounded-lg bg-white/10 hover:bg-white/20 transition-all duration-200' do %>
    <i class="fa fa-users text-yellow-300"></i>
    <span class="font-medium">Users</span>
  <% end %>


  <%= link_to home_activity_path,  
  data: { turbo_frame: :dashboard },
  class: 'flex items-center space-x-3 p-3 rounded-lg bg-white/10 hover:bg-white/20 transition-all duration-200' do %>
    <i class="fa fa-users text-yellow-300"></i>
    <span class="font-medium">Activity</span>
  <% end %>



</div>
</div>

  <!-- Contenido principal -->
  <div class="w-full h-[calc(100vh-4rem)] bg-gray-500 relative overflow-auto">
    <%= turbo_frame_tag :dashboard %>
  </div>
</div>


